# Cấu hình Google Cloud (Cho tính năng đồng bộ Google Sheets/Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app-name.vercel.app/api/auth/google/callback

# Cấu hình AI (Gemini)
# Thường AI Studio đã cung cấp sẵn biến GEMINI_API_KEY trong môi trường
GEMINI_API_KEY=

# URL ứng dụng
APP_URL=https://your-app-name.vercel.app
