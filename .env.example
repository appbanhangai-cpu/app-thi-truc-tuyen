# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE: Optional base URL for API calls.
# Defaults to window.location.origin if not set.
VITE_API_BASE=""

# GOOGLE_SHEET_WEBAPP_URL: URL of the Google Apps Script Web App to save exam results.
GOOGLE_SHEET_WEBAPP_URL="https://script.google.com/macros/s/AKfycbyOawiCl3Zr8Ez7wpXAo2oFW9lC3Xi6WE1vZSgpPelv2UBAL6856Ge8Gvh8i9YZEzhYeg/exec"

# GOOGLE_CLIENT_ID: Google OAuth Client ID for Drive API.
GOOGLE_CLIENT_ID=""

# GOOGLE_CLIENT_SECRET: Google OAuth Client Secret for Drive API.
GOOGLE_CLIENT_SECRET=""

# GOOGLE_REDIRECT_URI: Google OAuth Redirect URI for Drive API.
# Copy this: https://ais-dev-6maj32yolcpmkn6aharrdq-337123630939.asia-southeast1.run.app/api/auth/google/callback
GOOGLE_REDIRECT_URI="https://ais-dev-6maj32yolcpmkn6aharrdq-337123630939.asia-southeast1.run.app/api/auth/google/callback"
